{
  "expo": {
    "name": "Noor",
    "slug": "noor-mobile",
    "version": "1.0.0",
    "description": "Your Daily Quran Companion",
    "orientation": "portrait",
    "scheme": "noor",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safwan.noor",
      "infoPlist": {
        "CFBundleDisplayName": "Noor"
      }
    },
    "android": {
      "package": "com.safwan.noor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4332"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router"
    ]
  }
}
