{
  "number": 53,
  "name_arabic": "سُورَةُ النَّجۡمِ",
  "name_english": "An-Najm",
  "name_translation": "The Star",
  "revelation_type": "meccan",
  "ayah_count": 62,
  "juz_start": 27,
  "ayahs": [
    {
      "number": 4785,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلنَّجْمِ إِذَا هَوَىٰ",
      "text_translation": "By the star when it descends,",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4785.mp3"
    },
    {
      "number": 4786,
      "number_in_surah": 2,
      "text_arabic": "مَا ضَلَّ صَاحِبُكُمْ وَمَا غَوَىٰ",
      "text_translation": "Your companion [Muhammad] has not strayed, nor has he erred,",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4786.mp3"
    },
    {
      "number": 4787,
      "number_in_surah": 3,
      "text_arabic": "وَمَا يَنطِقُ عَنِ ٱلْهَوَىٰٓ",
      "text_translation": "Nor does he speak from [his own] inclination.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4787.mp3"
    },
    {
      "number": 4788,
      "number_in_surah": 4,
      "text_arabic": "إِنْ هُوَ إِلَّا وَحْىٌۭ يُوحَىٰ",
      "text_translation": "It is not but a revelation revealed,",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4788.mp3"
    },
    {
      "number": 4789,
      "number_in_surah": 5,
      "text_arabic": "عَلَّمَهُۥ شَدِيدُ ٱلْقُوَىٰ",
      "text_translation": "Taught to him by one intense in strength -",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4789.mp3"
    },
    {
      "number": 4790,
      "number_in_surah": 6,
      "text_arabic": "ذُو مِرَّةٍۢ فَٱسْتَوَىٰ",
      "text_translation": "One of soundness. And he rose to [his] true form",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4790.mp3"
    },
    {
      "number": 4791,
      "number_in_surah": 7,
      "text_arabic": "وَهُوَ بِٱلْأُفُقِ ٱلْأَعْلَىٰ",
      "text_translation": "While he was in the higher [part of the] horizon.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4791.mp3"
    },
    {
      "number": 4792,
      "number_in_surah": 8,
      "text_arabic": "ثُمَّ دَنَا فَتَدَلَّىٰ",
      "text_translation": "Then he approached and descended",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4792.mp3"
    },
    {
      "number": 4793,
      "number_in_surah": 9,
      "text_arabic": "فَكَانَ قَابَ قَوْسَيْنِ أَوْ أَدْنَىٰ",
      "text_translation": "And was at a distance of two bow lengths or nearer.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4793.mp3"
    },
    {
      "number": 4794,
      "number_in_surah": 10,
      "text_arabic": "فَأَوْحَىٰٓ إِلَىٰ عَبْدِهِۦ مَآ أَوْحَىٰ",
      "text_translation": "And he revealed to His Servant what he revealed.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4794.mp3"
    },
    {
      "number": 4795,
      "number_in_surah": 11,
      "text_arabic": "مَا كَذَبَ ٱلْفُؤَادُ مَا رَأَىٰٓ",
      "text_translation": "The heart did not lie [about] what it saw.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4795.mp3"
    },
    {
      "number": 4796,
      "number_in_surah": 12,
      "text_arabic": "أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ",
      "text_translation": "So will you dispute with him over what he saw?",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4796.mp3"
    },
    {
      "number": 4797,
      "number_in_surah": 13,
      "text_arabic": "وَلَقَدْ رَءَاهُ نَزْلَةً أُخْرَىٰ",
      "text_translation": "And he certainly saw him in another descent",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4797.mp3"
    },
    {
      "number": 4798,
      "number_in_surah": 14,
      "text_arabic": "عِندَ سِدْرَةِ ٱلْمُنتَهَىٰ",
      "text_translation": "At the Lote Tree of the Utmost Boundary -",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4798.mp3"
    },
    {
      "number": 4799,
      "number_in_surah": 15,
      "text_arabic": "عِندَهَا جَنَّةُ ٱلْمَأْوَىٰٓ",
      "text_translation": "Near it is the Garden of Refuge -",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4799.mp3"
    },
    {
      "number": 4800,
      "number_in_surah": 16,
      "text_arabic": "إِذْ يَغْشَى ٱلسِّدْرَةَ مَا يَغْشَىٰ",
      "text_translation": "When there covered the Lote Tree that which covered [it].",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4800.mp3"
    },
    {
      "number": 4801,
      "number_in_surah": 17,
      "text_arabic": "مَا زَاغَ ٱلْبَصَرُ وَمَا طَغَىٰ",
      "text_translation": "The sight [of the Prophet] did not swerve, nor did it transgress [its limit].",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4801.mp3"
    },
    {
      "number": 4802,
      "number_in_surah": 18,
      "text_arabic": "لَقَدْ رَأَىٰ مِنْ ءَايَٰتِ رَبِّهِ ٱلْكُبْرَىٰٓ",
      "text_translation": "He certainly saw of the greatest signs of his Lord.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4802.mp3"
    },
    {
      "number": 4803,
      "number_in_surah": 19,
      "text_arabic": "أَفَرَءَيْتُمُ ٱللَّٰتَ وَٱلْعُزَّىٰ",
      "text_translation": "So have you considered al-Lat and al-'Uzza?",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4803.mp3"
    },
    {
      "number": 4804,
      "number_in_surah": 20,
      "text_arabic": "وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلْأُخْرَىٰٓ",
      "text_translation": "And Manat, the third - the other one?",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4804.mp3"
    },
    {
      "number": 4805,
      "number_in_surah": 21,
      "text_arabic": "أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلْأُنثَىٰ",
      "text_translation": "Is the male for you and for Him the female?",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4805.mp3"
    },
    {
      "number": 4806,
      "number_in_surah": 22,
      "text_arabic": "تِلْكَ إِذًۭا قِسْمَةٌۭ ضِيزَىٰٓ",
      "text_translation": "That, then, is an unjust division.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4806.mp3"
    },
    {
      "number": 4807,
      "number_in_surah": 23,
      "text_arabic": "إِنْ هِىَ إِلَّآ أَسْمَآءٌۭ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلْطَٰنٍ ۚ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهْوَى ٱلْأَنفُسُ ۖ وَلَقَدْ جَآءَهُم مِّن رَّبِّهِمُ ٱلْهُدَىٰٓ",
      "text_translation": "They are not but [mere] names you have named them - you and your forefathers - for which Allah has sent down no authority. They follow not except assumption and what [their] souls desire, and there has already come to them from their Lord guidance.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4807.mp3"
    },
    {
      "number": 4808,
      "number_in_surah": 24,
      "text_arabic": "أَمْ لِلْإِنسَٰنِ مَا تَمَنَّىٰ",
      "text_translation": "Or is there for man whatever he wishes?",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4808.mp3"
    },
    {
      "number": 4809,
      "number_in_surah": 25,
      "text_arabic": "فَلِلَّهِ ٱلْءَاخِرَةُ وَٱلْأُولَىٰ",
      "text_translation": "Rather, to Allah belongs the Hereafter and the first [life].",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4809.mp3"
    },
    {
      "number": 4810,
      "number_in_surah": 26,
      "text_arabic": "۞ وَكَم مِّن مَّلَكٍۢ فِى ٱلسَّمَٰوَٰتِ لَا تُغْنِى شَفَٰعَتُهُمْ شَيْـًٔا إِلَّا مِنۢ بَعْدِ أَن يَأْذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرْضَىٰٓ",
      "text_translation": "And how many angels there are in the heavens whose intercession will not avail at all except [only] after Allah has permitted [it] to whom He wills and approves.",
      "juz": 27,
      "page": 526,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4810.mp3"
    },
    {
      "number": 4811,
      "number_in_surah": 27,
      "text_arabic": "إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ لَيُسَمُّونَ ٱلْمَلَٰٓئِكَةَ تَسْمِيَةَ ٱلْأُنثَىٰ",
      "text_translation": "Indeed, those who do not believe in the Hereafter name the angels female names,",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4811.mp3"
    },
    {
      "number": 4812,
      "number_in_surah": 28,
      "text_arabic": "وَمَا لَهُم بِهِۦ مِنْ عِلْمٍ ۖ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ ۖ وَإِنَّ ٱلظَّنَّ لَا يُغْنِى مِنَ ٱلْحَقِّ شَيْـًۭٔا",
      "text_translation": "And they have thereof no knowledge. They follow not except assumption, and indeed, assumption avails not against the truth at all.",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4812.mp3"
    },
    {
      "number": 4813,
      "number_in_surah": 29,
      "text_arabic": "فَأَعْرِضْ عَن مَّن تَوَلَّىٰ عَن ذِكْرِنَا وَلَمْ يُرِدْ إِلَّا ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "text_translation": "So turn away from whoever turns his back on Our message and desires not except the worldly life.",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4813.mp3"
    },
    {
      "number": 4814,
      "number_in_surah": 30,
      "text_arabic": "ذَٰلِكَ مَبْلَغُهُم مِّنَ ٱلْعِلْمِ ۚ إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِمَنِ ٱهْتَدَىٰ",
      "text_translation": "That is their sum of knowledge. Indeed, your Lord is most knowing of who strays from His way, and He is most knowing of who is guided.",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4814.mp3"
    },
    {
      "number": 4815,
      "number_in_surah": 31,
      "text_arabic": "وَلِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ لِيَجْزِىَ ٱلَّذِينَ أَسَٰٓـُٔوا۟ بِمَا عَمِلُوا۟ وَيَجْزِىَ ٱلَّذِينَ أَحْسَنُوا۟ بِٱلْحُسْنَى",
      "text_translation": "And to Allah belongs whatever is in the heavens and whatever is in the earth - that He may recompense those who do evil with [the penalty of] what they have done and recompense those who do good with the best [reward] -",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4815.mp3"
    },
    {
      "number": 4816,
      "number_in_surah": 32,
      "text_arabic": "ٱلَّذِينَ يَجْتَنِبُونَ كَبَٰٓئِرَ ٱلْإِثْمِ وَٱلْفَوَٰحِشَ إِلَّا ٱللَّمَمَ ۚ إِنَّ رَبَّكَ وَٰسِعُ ٱلْمَغْفِرَةِ ۚ هُوَ أَعْلَمُ بِكُمْ إِذْ أَنشَأَكُم مِّنَ ٱلْأَرْضِ وَإِذْ أَنتُمْ أَجِنَّةٌۭ فِى بُطُونِ أُمَّهَٰتِكُمْ ۖ فَلَا تُزَكُّوٓا۟ أَنفُسَكُمْ ۖ هُوَ أَعْلَمُ بِمَنِ ٱتَّقَىٰٓ",
      "text_translation": "Those who avoid the major sins and immoralities, only [committing] slight ones. Indeed, your Lord is vast in forgiveness. He was most knowing of you when He produced you from the earth and when you were fetuses in the wombs of your mothers. So do not claim yourselves to be pure; He is most knowing of who fears Him.",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4816.mp3"
    },
    {
      "number": 4817,
      "number_in_surah": 33,
      "text_arabic": "أَفَرَءَيْتَ ٱلَّذِى تَوَلَّىٰ",
      "text_translation": "Have you seen the one who turned away",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4817.mp3"
    },
    {
      "number": 4818,
      "number_in_surah": 34,
      "text_arabic": "وَأَعْطَىٰ قَلِيلًۭا وَأَكْدَىٰٓ",
      "text_translation": "And gave a little and [then] refrained?",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4818.mp3"
    },
    {
      "number": 4819,
      "number_in_surah": 35,
      "text_arabic": "أَعِندَهُۥ عِلْمُ ٱلْغَيْبِ فَهُوَ يَرَىٰٓ",
      "text_translation": "Does he have knowledge of the unseen, so he sees?",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4819.mp3"
    },
    {
      "number": 4820,
      "number_in_surah": 36,
      "text_arabic": "أَمْ لَمْ يُنَبَّأْ بِمَا فِى صُحُفِ مُوسَىٰ",
      "text_translation": "Or has he not been informed of what was in the scriptures of Moses",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4820.mp3"
    },
    {
      "number": 4821,
      "number_in_surah": 37,
      "text_arabic": "وَإِبْرَٰهِيمَ ٱلَّذِى وَفَّىٰٓ",
      "text_translation": "And [of] Abraham, who fulfilled [his obligations] -",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4821.mp3"
    },
    {
      "number": 4822,
      "number_in_surah": 38,
      "text_arabic": "أَلَّا تَزِرُ وَازِرَةٌۭ وِزْرَ أُخْرَىٰ",
      "text_translation": "That no bearer of burdens will bear the burden of another",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4822.mp3"
    },
    {
      "number": 4823,
      "number_in_surah": 39,
      "text_arabic": "وَأَن لَّيْسَ لِلْإِنسَٰنِ إِلَّا مَا سَعَىٰ",
      "text_translation": "And that there is not for man except that [good] for which he strives",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4823.mp3"
    },
    {
      "number": 4824,
      "number_in_surah": 40,
      "text_arabic": "وَأَنَّ سَعْيَهُۥ سَوْفَ يُرَىٰ",
      "text_translation": "And that his effort is going to be seen -",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4824.mp3"
    },
    {
      "number": 4825,
      "number_in_surah": 41,
      "text_arabic": "ثُمَّ يُجْزَىٰهُ ٱلْجَزَآءَ ٱلْأَوْفَىٰ",
      "text_translation": "Then he will be recompensed for it with the fullest recompense",
      "juz": 27,
      "page": 527,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4825.mp3"
    },
    {
      "number": 4826,
      "number_in_surah": 42,
      "text_arabic": "وَأَنَّ إِلَىٰ رَبِّكَ ٱلْمُنتَهَىٰ",
      "text_translation": "And that to your Lord is the finality",
      "juz": 27,
      "page": 527,
