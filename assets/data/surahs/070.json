{
  "number": 70,
  "name_arabic": "سُورَةُ المَعَارِجِ",
  "name_english": "Al-Ma'aarij",
  "name_translation": "The Ascending Stairways",
  "revelation_type": "meccan",
  "ayah_count": 44,
  "juz_start": 29,
  "ayahs": [
    {
      "number": 5376,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَأَلَ سَآئِلٌۢ بِعَذَابٍۢ وَاقِعٍۢ",
      "text_translation": "A supplicant asked for a punishment bound to happen",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5376.mp3"
    },
    {
      "number": 5377,
      "number_in_surah": 2,
      "text_arabic": "لِّلْكَٰفِرِينَ لَيْسَ لَهُۥ دَافِعٌۭ",
      "text_translation": "To the disbelievers; of it there is no preventer.",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5377.mp3"
    },
    {
      "number": 5378,
      "number_in_surah": 3,
      "text_arabic": "مِّنَ ٱللَّهِ ذِى ٱلْمَعَارِجِ",
      "text_translation": "[It is] from Allah, owner of the ways of ascent.",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5378.mp3"
    },
    {
      "number": 5379,
      "number_in_surah": 4,
      "text_arabic": "تَعْرُجُ ٱلْمَلَٰٓئِكَةُ وَٱلرُّوحُ إِلَيْهِ فِى يَوْمٍۢ كَانَ مِقْدَارُهُۥ خَمْسِينَ أَلْفَ سَنَةٍۢ",
      "text_translation": "The angels and the Spirit will ascend to Him during a Day the extent of which is fifty thousand years.",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5379.mp3"
    },
    {
      "number": 5380,
      "number_in_surah": 5,
      "text_arabic": "فَٱصْبِرْ صَبْرًۭا جَمِيلًا",
      "text_translation": "So be patient with gracious patience.",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5380.mp3"
    },
    {
      "number": 5381,
      "number_in_surah": 6,
      "text_arabic": "إِنَّهُمْ يَرَوْنَهُۥ بَعِيدًۭا",
      "text_translation": "Indeed, they see it [as] distant,",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5381.mp3"
    },
    {
      "number": 5382,
      "number_in_surah": 7,
      "text_arabic": "وَنَرَىٰهُ قَرِيبًۭا",
      "text_translation": "But We see it [as] near.",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5382.mp3"
    },
    {
      "number": 5383,
      "number_in_surah": 8,
      "text_arabic": "يَوْمَ تَكُونُ ٱلسَّمَآءُ كَٱلْمُهْلِ",
      "text_translation": "On the Day the sky will be like murky oil,",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5383.mp3"
    },
    {
      "number": 5384,
      "number_in_surah": 9,
      "text_arabic": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ",
      "text_translation": "And the mountains will be like wool,",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5384.mp3"
    },
    {
      "number": 5385,
      "number_in_surah": 10,
      "text_arabic": "وَلَا يَسْـَٔلُ حَمِيمٌ حَمِيمًۭا",
      "text_translation": "And no friend will ask [anything of] a friend,",
      "juz": 29,
      "page": 568,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5385.mp3"
    },
    {
      "number": 5386,
      "number_in_surah": 11,
      "text_arabic": "يُبَصَّرُونَهُمْ ۚ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ",
      "text_translation": "They will be shown each other. The criminal will wish that he could be ransomed from the punishment of that Day by his children",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5386.mp3"
    },
    {
      "number": 5387,
      "number_in_surah": 12,
      "text_arabic": "وَصَٰحِبَتِهِۦ وَأَخِيهِ",
      "text_translation": "And his wife and his brother",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5387.mp3"
    },
    {
      "number": 5388,
      "number_in_surah": 13,
      "text_arabic": "وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ",
      "text_translation": "And his nearest kindred who shelter him",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5388.mp3"
    },
    {
      "number": 5389,
      "number_in_surah": 14,
      "text_arabic": "وَمَن فِى ٱلْأَرْضِ جَمِيعًۭا ثُمَّ يُنجِيهِ",
      "text_translation": "And whoever is on earth entirely [so] then it could save him.",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5389.mp3"
    },
    {
      "number": 5390,
      "number_in_surah": 15,
      "text_arabic": "كَلَّآ ۖ إِنَّهَا لَظَىٰ",
      "text_translation": "No! Indeed, it is the Flame [of Hell],",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5390.mp3"
    },
    {
      "number": 5391,
      "number_in_surah": 16,
      "text_arabic": "نَزَّاعَةًۭ لِّلشَّوَىٰ",
      "text_translation": "A remover of exteriors.",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5391.mp3"
    },
    {
      "number": 5392,
      "number_in_surah": 17,
      "text_arabic": "تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ",
      "text_translation": "It invites he who turned his back [on truth] and went away [from obedience]",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5392.mp3"
    },
    {
      "number": 5393,
      "number_in_surah": 18,
      "text_arabic": "وَجَمَعَ فَأَوْعَىٰٓ",
      "text_translation": "And collected [wealth] and hoarded.",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5393.mp3"
    },
    {
      "number": 5394,
      "number_in_surah": 19,
      "text_arabic": "۞ إِنَّ ٱلْإِنسَٰنَ خُلِقَ هَلُوعًا",
      "text_translation": "Indeed, mankind was created anxious:",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5394.mp3"
    },
    {
      "number": 5395,
      "number_in_surah": 20,
      "text_arabic": "إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعًۭا",
      "text_translation": "When evil touches him, impatient,",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5395.mp3"
    },
    {
      "number": 5396,
      "number_in_surah": 21,
      "text_arabic": "وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا",
      "text_translation": "And when good touches him, withholding [of it],",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5396.mp3"
    },
    {
      "number": 5397,
      "number_in_surah": 22,
      "text_arabic": "إِلَّا ٱلْمُصَلِّينَ",
      "text_translation": "Except the observers of prayer -",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5397.mp3"
    },
    {
      "number": 5398,
      "number_in_surah": 23,
      "text_arabic": "ٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَآئِمُونَ",
      "text_translation": "Those who are constant in their prayer",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5398.mp3"
    },
    {
      "number": 5399,
      "number_in_surah": 24,
      "text_arabic": "وَٱلَّذِينَ فِىٓ أَمْوَٰلِهِمْ حَقٌّۭ مَّعْلُومٌۭ",
      "text_translation": "And those within whose wealth is a known right",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5399.mp3"
    },
    {
      "number": 5400,
      "number_in_surah": 25,
      "text_arabic": "لِّلسَّآئِلِ وَٱلْمَحْرُومِ",
      "text_translation": "For the petitioner and the deprived -",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5400.mp3"
    },
    {
      "number": 5401,
      "number_in_surah": 26,
      "text_arabic": "وَٱلَّذِينَ يُصَدِّقُونَ بِيَوْمِ ٱلدِّينِ",
      "text_translation": "And those who believe in the Day of Recompense",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5401.mp3"
    },
    {
      "number": 5402,
      "number_in_surah": 27,
      "text_arabic": "وَٱلَّذِينَ هُم مِّنْ عَذَابِ رَبِّهِم مُّشْفِقُونَ",
      "text_translation": "And those who are fearful of the punishment of their Lord -",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5402.mp3"
    },
    {
      "number": 5403,
      "number_in_surah": 28,
      "text_arabic": "إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍۢ",
      "text_translation": "Indeed, the punishment of their Lord is not that from which one is safe -",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5403.mp3"
    },
    {
      "number": 5404,
      "number_in_surah": 29,
      "text_arabic": "وَٱلَّذِينَ هُمْ لِفُرُوجِهِمْ حَٰفِظُونَ",
      "text_translation": "And those who guard their private parts",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5404.mp3"
    },
    {
      "number": 5405,
      "number_in_surah": 30,
      "text_arabic": "إِلَّا عَلَىٰٓ أَزْوَٰجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ",
      "text_translation": "Except from their wives or those their right hands possess, for indeed, they are not to be blamed -",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5405.mp3"
    },
    {
      "number": 5406,
      "number_in_surah": 31,
      "text_arabic": "فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَٰٓئِكَ هُمُ ٱلْعَادُونَ",
      "text_translation": "But whoever seeks beyond that, then they are the transgressors -",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5406.mp3"
    },
    {
      "number": 5407,
      "number_in_surah": 32,
      "text_arabic": "وَٱلَّذِينَ هُمْ لِأَمَٰنَٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَ",
      "text_translation": "And those who are to their trusts and promises attentive",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5407.mp3"
    },
    {
      "number": 5408,
      "number_in_surah": 33,
      "text_arabic": "وَٱلَّذِينَ هُم بِشَهَٰدَٰتِهِمْ قَآئِمُونَ",
      "text_translation": "And those who are in their testimonies upright",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5408.mp3"
    },
    {
      "number": 5409,
      "number_in_surah": 34,
      "text_arabic": "وَٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ",
      "text_translation": "And those who [carefully] maintain their prayer:",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5409.mp3"
    },
    {
      "number": 5410,
      "number_in_surah": 35,
      "text_arabic": "أُو۟لَٰٓئِكَ فِى جَنَّٰتٍۢ مُّكْرَمُونَ",
      "text_translation": "They will be in gardens, honored.",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5410.mp3"
    },
    {
      "number": 5411,
      "number_in_surah": 36,
      "text_arabic": "فَمَالِ ٱلَّذِينَ كَفَرُوا۟ قِبَلَكَ مُهْطِعِينَ",
      "text_translation": "So what is [the matter] with those who disbelieve, hastening [from] before you, [O Muhammad],",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5411.mp3"
    },
    {
      "number": 5412,
      "number_in_surah": 37,
      "text_arabic": "عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ",
      "text_translation": "[To sit] on [your] right and [your] left in separate groups?",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5412.mp3"
    },
    {
      "number": 5413,
      "number_in_surah": 38,
      "text_arabic": "أَيَطْمَعُ كُلُّ ٱمْرِئٍۢ مِّنْهُمْ أَن يُدْخَلَ جَنَّةَ نَعِيمٍۢ",
      "text_translation": "Does every person among them aspire to enter a garden of pleasure?",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5413.mp3"
    },
    {
      "number": 5414,
      "number_in_surah": 39,
      "text_arabic": "كَلَّآ ۖ إِنَّا خَلَقْنَٰهُم مِّمَّا يَعْلَمُونَ",
      "text_translation": "No! Indeed, We have created them from that which they know.",
      "juz": 29,
      "page": 569,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5414.mp3"
    },
    {
      "number": 5415,
      "number_in_surah": 40,
      "text_arabic": "فَلَآ أُقْسِمُ بِرَبِّ ٱلْمَشَٰرِقِ وَٱلْمَغَٰرِبِ إِنَّا لَقَٰدِرُونَ",
      "text_translation": "So I swear by the Lord of [all] risings and settings that indeed We are able",
      "juz": 29,
      "page": 570,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5415.mp3"
    },
    {
      "number": 5416,
      "number_in_surah": 41,
      "text_arabic": "عَلَىٰٓ أَن نُّبَدِّلَ خَيْرًۭا مِّنْهُمْ وَمَا نَحْنُ بِمَسْبُوقِينَ",
      "text_translation": "To replace them with better than them; and We are not to be outdone.",
      "juz": 29,
      "page": 570,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5416.mp3"
    },
    {
      "number": 5417,
      "number_in_surah": 42,
      "text_arabic": "فَذَرْهُمْ يَخُوضُوا۟ وَيَلْعَبُوا۟ حَتَّىٰ يُلَٰقُوا۟ يَوْمَهُمُ ٱلَّذِى يُوعَدُونَ",
      "text_translation": "So leave them to converse vainly and amuse themselves until they meet their Day which they are promised -",
      "juz": 29,
      "page": 570,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5417.mp3"
    },
    {
      "number": 5418,
      "number_in_surah": 43,
      "text_arabic": "يَوْمَ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ سِرَاعًۭا كَأَنَّهُمْ إِلَىٰ نُصُبٍۢ يُوفِضُونَ",
      "text_translation": "The Day they will emerge from the graves rapidly as if they were, toward an erected idol, hastening.",
      "juz": 29,
      "page": 570,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5418.mp3"
    },
    {
      "number": 5419,
      "number_in_surah": 44,
      "text_arabic": "خَٰشِعَةً أَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌۭ ۚ ذَٰلِكَ ٱلْيَوْمُ ٱلَّذِى كَانُوا۟ يُوعَدُونَ",
      "text_translation": "Their eyes humbled, humiliation will cover them. That is the Day which they had been promised.",
      "juz": 29,
      "page": 570,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5419.mp3"
    }
  ]
}