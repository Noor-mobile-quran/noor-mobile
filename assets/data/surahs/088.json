{
  "number": 88,
  "name_arabic": "سُورَةُ الغَاشِيَةِ",
  "name_english": "Al-Ghaashiya",
  "name_translation": "The Overwhelming",
  "revelation_type": "meccan",
  "ayah_count": 26,
  "juz_start": 30,
  "ayahs": [
    {
      "number": 5968,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ",
      "text_translation": "Has there reached you the report of the Overwhelming [event]?",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5968.mp3"
    },
    {
      "number": 5969,
      "number_in_surah": 2,
      "text_arabic": "وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ",
      "text_translation": "[Some] faces, that Day, will be humbled,",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5969.mp3"
    },
    {
      "number": 5970,
      "number_in_surah": 3,
      "text_arabic": "عَامِلَةٌۭ نَّاصِبَةٌۭ",
      "text_translation": "Working [hard] and exhausted.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5970.mp3"
    },
    {
      "number": 5971,
      "number_in_surah": 4,
      "text_arabic": "تَصْلَىٰ نَارًا حَامِيَةًۭ",
      "text_translation": "They will [enter to] burn in an intensely hot Fire.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5971.mp3"
    },
    {
      "number": 5972,
      "number_in_surah": 5,
      "text_arabic": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ",
      "text_translation": "They will be given drink from a boiling spring.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5972.mp3"
    },
    {
      "number": 5973,
      "number_in_surah": 6,
      "text_arabic": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ",
      "text_translation": "For them there will be no food except from a poisonous, thorny plant",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5973.mp3"
    },
    {
      "number": 5974,
      "number_in_surah": 7,
      "text_arabic": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ",
      "text_translation": "Which neither nourishes nor avails against hunger.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5974.mp3"
    },
    {
      "number": 5975,
      "number_in_surah": 8,
      "text_arabic": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ",
      "text_translation": "[Other] faces, that Day, will show pleasure.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5975.mp3"
    },
    {
      "number": 5976,
      "number_in_surah": 9,
      "text_arabic": "لِّسَعْيِهَا رَاضِيَةٌۭ",
      "text_translation": "With their effort [they are] satisfied",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5976.mp3"
    },
    {
      "number": 5977,
      "number_in_surah": 10,
      "text_arabic": "فِى جَنَّةٍ عَالِيَةٍۢ",
      "text_translation": "In an elevated garden,",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5977.mp3"
    },
    {
      "number": 5978,
      "number_in_surah": 11,
      "text_arabic": "لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ",
      "text_translation": "Wherein they will hear no unsuitable speech.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5978.mp3"
    },
    {
      "number": 5979,
      "number_in_surah": 12,
      "text_arabic": "فِيهَا عَيْنٌۭ جَارِيَةٌۭ",
      "text_translation": "Within it is a flowing spring.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5979.mp3"
    },
    {
      "number": 5980,
      "number_in_surah": 13,
      "text_arabic": "فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ",
      "text_translation": "Within it are couches raised high",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5980.mp3"
    },
    {
      "number": 5981,
      "number_in_surah": 14,
      "text_arabic": "وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ",
      "text_translation": "And cups put in place",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5981.mp3"
    },
    {
      "number": 5982,
      "number_in_surah": 15,
      "text_arabic": "وَنَمَارِقُ مَصْفُوفَةٌۭ",
      "text_translation": "And cushions lined up",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5982.mp3"
    },
    {
      "number": 5983,
      "number_in_surah": 16,
      "text_arabic": "وَزَرَابِىُّ مَبْثُوثَةٌ",
      "text_translation": "And carpets spread around.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5983.mp3"
    },
    {
      "number": 5984,
      "number_in_surah": 17,
      "text_arabic": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
      "text_translation": "Then do they not look at the camels - how they are created?",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5984.mp3"
    },
    {
      "number": 5985,
      "number_in_surah": 18,
      "text_arabic": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
      "text_translation": "And at the sky - how it is raised?",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5985.mp3"
    },
    {
      "number": 5986,
      "number_in_surah": 19,
      "text_arabic": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
      "text_translation": "And at the mountains - how they are erected?",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5986.mp3"
    },
    {
      "number": 5987,
      "number_in_surah": 20,
      "text_arabic": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
      "text_translation": "And at the earth - how it is spread out?",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5987.mp3"
    },
    {
      "number": 5988,
      "number_in_surah": 21,
      "text_arabic": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ",
      "text_translation": "So remind, [O Muhammad]; you are only a reminder.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5988.mp3"
    },
    {
      "number": 5989,
      "number_in_surah": 22,
      "text_arabic": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
      "text_translation": "You are not over them a controller.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5989.mp3"
    },
    {
      "number": 5990,
      "number_in_surah": 23,
      "text_arabic": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
      "text_translation": "However, he who turns away and disbelieves -",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5990.mp3"
    },
    {
      "number": 5991,
      "number_in_surah": 24,
      "text_arabic": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
      "text_translation": "Then Allah will punish him with the greatest punishment.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5991.mp3"
    },
    {
      "number": 5992,
      "number_in_surah": 25,
      "text_arabic": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
      "text_translation": "Indeed, to Us is their return.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5992.mp3"
    },
    {
      "number": 5993,
      "number_in_surah": 26,
      "text_arabic": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
      "text_translation": "Then indeed, upon Us is their account.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5993.mp3"
    }
  ]
}