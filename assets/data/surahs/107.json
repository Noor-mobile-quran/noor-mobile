      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
      "text_translation": "Have you seen the one who denies the Recompense?",
      "juz": 30,
      "page": 602,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6198.mp3"
    },
    {
      "number": 6199,
      "number_in_surah": 2,
      "text_arabic": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
      "text_translation": "For that is the one who drives away the orphan",
      "juz": 30,
      "page": 602,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6199.mp3"
    },
    {
      "number": 6200,
      "number_in_surah": 3,
      "text_arabic": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "text_translation": "And does not encourage the feeding of the poor.",
      "juz": 30,
      "page": 602,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6200.mp3"
    },
    {
      "number": 6201,
      "number_in_surah": 4,
      "text_arabic": "فَوَيْلٌۭ لِّلْمُصَلِّينَ",
