      "number_in_surah": 5,
      "text_arabic": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "text_translation": "[But] who are heedless of their prayer -",
      "juz": 30,
      "page": 602,
