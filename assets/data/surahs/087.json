{
  "number": 87,
  "name_arabic": "سُورَةُ الأَعۡلَىٰ",
  "name_english": "Al-A'laa",
  "name_translation": "The Most High",
  "revelation_type": "meccan",
  "ayah_count": 19,
  "juz_start": 30,
  "ayahs": [
    {
      "number": 5949,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
      "text_translation": "Exalt the name of your Lord, the Most High,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5949.mp3"
    },
    {
      "number": 5950,
      "number_in_surah": 2,
      "text_arabic": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
      "text_translation": "Who created and proportioned",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5950.mp3"
    },
    {
      "number": 5951,
      "number_in_surah": 3,
      "text_arabic": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
      "text_translation": "And who destined and [then] guided",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5951.mp3"
    },
    {
      "number": 5952,
      "number_in_surah": 4,
      "text_arabic": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
      "text_translation": "And who brings out the pasture",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5952.mp3"
    },
    {
      "number": 5953,
      "number_in_surah": 5,
      "text_arabic": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
      "text_translation": "And [then] makes it black stubble.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5953.mp3"
    },
    {
      "number": 5954,
      "number_in_surah": 6,
      "text_arabic": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
      "text_translation": "We will make you recite, [O Muhammad], and you will not forget,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5954.mp3"
    },
    {
      "number": 5955,
      "number_in_surah": 7,
      "text_arabic": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
      "text_translation": "Except what Allah should will. Indeed, He knows what is declared and what is hidden.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5955.mp3"
    },
    {
      "number": 5956,
      "number_in_surah": 8,
      "text_arabic": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "text_translation": "And We will ease you toward ease.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5956.mp3"
    },
    {
      "number": 5957,
      "number_in_surah": 9,
      "text_arabic": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
      "text_translation": "So remind, if the reminder should benefit;",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5957.mp3"
    },
    {
      "number": 5958,
      "number_in_surah": 10,
      "text_arabic": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "text_translation": "He who fears [Allah] will be reminded.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5958.mp3"
    },
    {
      "number": 5959,
      "number_in_surah": 11,
      "text_arabic": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
      "text_translation": "But the wretched one will avoid it -",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5959.mp3"
    },
    {
      "number": 5960,
      "number_in_surah": 12,
      "text_arabic": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
      "text_translation": "[He] who will [enter and] burn in the greatest Fire,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5960.mp3"
    },
    {
      "number": 5961,
      "number_in_surah": 13,
      "text_arabic": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "text_translation": "Neither dying therein nor living.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5961.mp3"
    },
    {
      "number": 5962,
      "number_in_surah": 14,
      "text_arabic": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
      "text_translation": "He has certainly succeeded who purifies himself",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5962.mp3"
    },
    {
      "number": 5963,
      "number_in_surah": 15,
      "text_arabic": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
      "text_translation": "And mentions the name of his Lord and prays.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5963.mp3"
    },
    {
      "number": 5964,
      "number_in_surah": 16,
      "text_arabic": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "text_translation": "But you prefer the worldly life,",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5964.mp3"
    },
    {
      "number": 5965,
      "number_in_surah": 17,
      "text_arabic": "وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ",
      "text_translation": "While the Hereafter is better and more enduring.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5965.mp3"
    },
    {
      "number": 5966,
      "number_in_surah": 18,
      "text_arabic": "إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
      "text_translation": "Indeed, this is in the former scriptures,",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5966.mp3"
    },
    {
      "number": 5967,
      "number_in_surah": 19,
      "text_arabic": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
      "text_translation": "The scriptures of Abraham and Moses.",
      "juz": 30,
      "page": 592,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5967.mp3"
    }
  ]
}