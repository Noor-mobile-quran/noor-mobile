  "ayahs": [
    {
      "number": 6169,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ",
      "text_translation": "Competition in [worldly] increase diverts you",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6169.mp3",
      "text_translation_ur": "تمہیں حرص نے غافل کر دیا"
    },
    {
      "number": 6170,
      "number_in_surah": 2,
      "text_arabic": "حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ",
      "text_translation": "Until you visit the graveyards.",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6170.mp3",
      "text_translation_ur": "یہاں تک کہ قبریں جا دیکھیں"
    },
    {
      "number": 6171,
      "number_in_surah": 3,
      "text_arabic": "كَلَّا سَوْفَ تَعْلَمُونَ",
      "text_translation": "No! You are going to know.",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6171.mp3",
      "text_translation_ur": "ایسا نہیں آئندہ تم جان لو گے"
    },
    {
      "number": 6172,
      "number_in_surah": 4,
      "text_arabic": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
      "text_translation": "Then no! You are going to know.",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6172.mp3",
      "text_translation_ur": "پھر ایسا نہیں چاہیئے آئندہ تم جان لو گے"
    },
    {
      "number": 6173,
      "number_in_surah": 5,
      "text_arabic": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ",
      "text_translation": "No! If you only knew with knowledge of certainty...",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6173.mp3",
      "text_translation_ur": "ایسا نہیں چاہیئے کاش تم یقینی طور پر جانتے"
    },
    {
      "number": 6174,
      "number_in_surah": 6,
      "text_arabic": "لَتَرَوُنَّ ٱلْجَحِيمَ",
      "text_translation": "You will surely see the Hellfire.",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6174.mp3",
      "text_translation_ur": "البتہ تم ضرور دوزخ کو دیکھو گے"
    },
    {
      "number": 6175,
      "number_in_surah": 7,
      "text_arabic": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ",
      "text_translation": "Then you will surely see it with the eye of certainty.",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6175.mp3",
      "text_translation_ur": "پھر تم اسے ضرور بالکل یقینی طور پر دیکھو گے"
    },
    {
      "number": 6176,
      "number_in_surah": 8,
      "text_arabic": "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ",
      "text_translation": "Then you will surely be asked that Day about pleasure.",
      "juz": 30,
      "page": 600,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6176.mp3",
      "text_translation_ur": "پھر اس دن تم سے نعمتوں کے متعلق پوچھا جائے گا"
