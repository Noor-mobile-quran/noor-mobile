    {
      "number": 6218,
      "number_in_surah": 2,
      "text_arabic": "مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ",
      "text_translation": "His wealth will not avail him or that which he gained.",
