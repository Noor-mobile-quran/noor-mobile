  "name_english": "Az-Zalzala",
  "name_translation": "The Earthquake",
  "revelation_type": "medinan",
  "ayah_count": 8,
  "juz_start": 30,
  "ayahs": [
    {
      "number": 6139,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا",
      "text_translation": "When the earth is shaken with its [final] earthquake",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6139.mp3"
    },
    {
      "number": 6140,
      "number_in_surah": 2,
      "text_arabic": "وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا",
      "text_translation": "And the earth discharges its burdens",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6140.mp3"
    },
    {
      "number": 6141,
      "number_in_surah": 3,
      "text_arabic": "وَقَالَ ٱلْإِنسَٰنُ مَا لَهَا",
      "text_translation": "And man says, \"What is [wrong] with it?\" -",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6141.mp3"
    },
    {
      "number": 6142,
      "number_in_surah": 4,
      "text_arabic": "يَوْمَئِذٍۢ تُحَدِّثُ أَخْبَارَهَا",
      "text_translation": "That Day, it will report its news",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6142.mp3"
    },
    {
      "number": 6143,
      "number_in_surah": 5,
      "text_arabic": "بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا",
      "text_translation": "Because your Lord has commanded it.",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6143.mp3"
    },
    {
      "number": 6144,
      "number_in_surah": 6,
      "text_arabic": "يَوْمَئِذٍۢ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًۭا لِّيُرَوْا۟ أَعْمَٰلَهُمْ",
      "text_translation": "That Day, the people will depart separated [into categories] to be shown [the result of] their deeds.",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6144.mp3"
    },
    {
      "number": 6145,
      "number_in_surah": 7,
      "text_arabic": "فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًۭا يَرَهُۥ",
      "text_translation": "So whoever does an atom's weight of good will see it,",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6145.mp3"
    },
    {
      "number": 6146,
      "number_in_surah": 8,
      "text_arabic": "وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍۢ شَرًّۭا يَرَهُۥ",
      "text_translation": "And whoever does an atom's weight of evil will see it.",
      "juz": 30,
      "page": 599,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/6146.mp3"
    }
  ]
