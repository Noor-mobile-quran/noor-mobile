{
  "number": 86,
  "name_arabic": "سُورَةُ الطَّارِقِ",
  "name_english": "At-Taariq",
  "name_translation": "The Morning Star",
  "revelation_type": "meccan",
  "ayah_count": 17,
  "juz_start": 30,
  "ayahs": [
    {
      "number": 5932,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "text_translation": "By the sky and the night comer -",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5932.mp3"
    },
    {
      "number": 5933,
      "number_in_surah": 2,
      "text_arabic": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
      "text_translation": "And what can make you know what is the night comer?",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5933.mp3"
    },
    {
      "number": 5934,
      "number_in_surah": 3,
      "text_arabic": "ٱلنَّجْمُ ٱلثَّاقِبُ",
      "text_translation": "It is the piercing star -",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5934.mp3"
    },
    {
      "number": 5935,
      "number_in_surah": 4,
      "text_arabic": "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
      "text_translation": "There is no soul but that it has over it a protector.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5935.mp3"
    },
    {
      "number": 5936,
      "number_in_surah": 5,
      "text_arabic": "فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ",
      "text_translation": "So let man observe from what he was created.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5936.mp3"
    },
    {
      "number": 5937,
      "number_in_surah": 6,
      "text_arabic": "خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ",
      "text_translation": "He was created from a fluid, ejected,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5937.mp3"
    },
    {
      "number": 5938,
      "number_in_surah": 7,
      "text_arabic": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
      "text_translation": "Emerging from between the backbone and the ribs.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5938.mp3"
    },
    {
      "number": 5939,
      "number_in_surah": 8,
      "text_arabic": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ",
      "text_translation": "Indeed, Allah, to return him [to life], is Able.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5939.mp3"
    },
    {
      "number": 5940,
      "number_in_surah": 9,
      "text_arabic": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
      "text_translation": "The Day when secrets will be put on trial,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5940.mp3"
    },
    {
      "number": 5941,
      "number_in_surah": 10,
      "text_arabic": "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
      "text_translation": "Then man will have no power or any helper.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5941.mp3"
    },
    {
      "number": 5942,
      "number_in_surah": 11,
      "text_arabic": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "text_translation": "By the sky which returns [rain]",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5942.mp3"
    },
    {
      "number": 5943,
      "number_in_surah": 12,
      "text_arabic": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "text_translation": "And [by] the earth which cracks open,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5943.mp3"
    },
    {
      "number": 5944,
      "number_in_surah": 13,
      "text_arabic": "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
      "text_translation": "Indeed, the Qur'an is a decisive statement,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5944.mp3"
    },
    {
      "number": 5945,
      "number_in_surah": 14,
      "text_arabic": "وَمَا هُوَ بِٱلْهَزْلِ",
      "text_translation": "And it is not amusement.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5945.mp3"
    },
    {
      "number": 5946,
      "number_in_surah": 15,
      "text_arabic": "إِنَّهُمْ يَكِيدُونَ كَيْدًۭا",
      "text_translation": "Indeed, they are planning a plan,",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5946.mp3"
    },
    {
      "number": 5947,
      "number_in_surah": 16,
      "text_arabic": "وَأَكِيدُ كَيْدًۭا",
      "text_translation": "But I am planning a plan.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5947.mp3"
    },
    {
      "number": 5948,
      "number_in_surah": 17,
      "text_arabic": "فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
      "text_translation": "So allow time for the disbelievers. Leave them awhile.",
      "juz": 30,
      "page": 591,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5948.mp3"
    }
  ]
}