  "ayahs": [
    {
      "number": 4902,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلرَّحْمَٰنُ",
      "text_translation": "The Most Merciful",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4902.mp3"
    },
    {
      "number": 4903,
      "number_in_surah": 2,
      "text_arabic": "عَلَّمَ ٱلْقُرْءَانَ",
      "text_translation": "Taught the Qur'an,",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4903.mp3"
    },
    {
      "number": 4904,
      "number_in_surah": 3,
      "text_arabic": "خَلَقَ ٱلْإِنسَٰنَ",
      "text_translation": "Created man,",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4904.mp3"
    },
    {
      "number": 4905,
      "number_in_surah": 4,
      "text_arabic": "عَلَّمَهُ ٱلْبَيَانَ",
      "text_translation": "[And] taught him eloquence.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4905.mp3"
    },
    {
      "number": 4906,
      "number_in_surah": 5,
      "text_arabic": "ٱلشَّمْسُ وَٱلْقَمَرُ بِحُسْبَانٍۢ",
      "text_translation": "The sun and the moon [move] by precise calculation,",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4906.mp3"
    },
    {
      "number": 4907,
      "number_in_surah": 6,
      "text_arabic": "وَٱلنَّجْمُ وَٱلشَّجَرُ يَسْجُدَانِ",
      "text_translation": "And the stars and trees prostrate.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4907.mp3"
    },
    {
      "number": 4908,
      "number_in_surah": 7,
      "text_arabic": "وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلْمِيزَانَ",
      "text_translation": "And the heaven He raised and imposed the balance",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4908.mp3"
    },
    {
      "number": 4909,
      "number_in_surah": 8,
      "text_arabic": "أَلَّا تَطْغَوْا۟ فِى ٱلْمِيزَانِ",
      "text_translation": "That you not transgress within the balance.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4909.mp3"
    },
    {
      "number": 4910,
      "number_in_surah": 9,
      "text_arabic": "وَأَقِيمُوا۟ ٱلْوَزْنَ بِٱلْقِسْطِ وَلَا تُخْسِرُوا۟ ٱلْمِيزَانَ",
      "text_translation": "And establish weight in justice and do not make deficient the balance.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4910.mp3"
    },
    {
      "number": 4911,
      "number_in_surah": 10,
      "text_arabic": "وَٱلْأَرْضَ وَضَعَهَا لِلْأَنَامِ",
      "text_translation": "And the earth He laid [out] for the creatures.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4911.mp3"
    },
    {
      "number": 4912,
      "number_in_surah": 11,
      "text_arabic": "فِيهَا فَٰكِهَةٌۭ وَٱلنَّخْلُ ذَاتُ ٱلْأَكْمَامِ",
      "text_translation": "Therein is fruit and palm trees having sheaths [of dates]",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4912.mp3"
    },
    {
      "number": 4913,
      "number_in_surah": 12,
      "text_arabic": "وَٱلْحَبُّ ذُو ٱلْعَصْفِ وَٱلرَّيْحَانُ",
      "text_translation": "And grain having husks and scented plants.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4913.mp3"
    },
    {
      "number": 4914,
      "number_in_surah": 13,
      "text_arabic": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ",
      "text_translation": "So which of the favors of your Lord would you deny?",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4914.mp3"
    },
    {
      "number": 4915,
      "number_in_surah": 14,
      "text_arabic": "خَلَقَ ٱلْإِنسَٰنَ مِن صَلْصَٰلٍۢ كَٱلْفَخَّارِ",
      "text_translation": "He created man from clay like [that of] pottery.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4915.mp3"
    },
    {
      "number": 4916,
      "number_in_surah": 15,
      "text_arabic": "وَخَلَقَ ٱلْجَآنَّ مِن مَّارِجٍۢ مِّن نَّارٍۢ",
      "text_translation": "And He created the jinn from a smokeless flame of fire.",
      "juz": 27,
      "page": 531,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/4916.mp3"
    },
    {
