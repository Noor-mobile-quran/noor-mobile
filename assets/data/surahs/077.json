{
  "number": 77,
  "name_arabic": "سُورَةُ المُرۡسَلَاتِ",
  "name_english": "Al-Mursalaat",
  "name_translation": "The Emissaries",
  "revelation_type": "meccan",
  "ayah_count": 50,
  "juz_start": 29,
  "ayahs": [
    {
      "number": 5623,
      "number_in_surah": 1,
      "text_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْمُرْسَلَٰتِ عُرْفًۭا",
      "text_translation": "By those [winds] sent forth in gusts",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5623.mp3"
    },
    {
      "number": 5624,
      "number_in_surah": 2,
      "text_arabic": "فَٱلْعَٰصِفَٰتِ عَصْفًۭا",
      "text_translation": "And the winds that blow violently",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5624.mp3"
    },
    {
      "number": 5625,
      "number_in_surah": 3,
      "text_arabic": "وَٱلنَّٰشِرَٰتِ نَشْرًۭا",
      "text_translation": "And [by] the winds that spread [clouds]",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5625.mp3"
    },
    {
      "number": 5626,
      "number_in_surah": 4,
      "text_arabic": "فَٱلْفَٰرِقَٰتِ فَرْقًۭا",
      "text_translation": "And those [angels] who bring criterion",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5626.mp3"
    },
    {
      "number": 5627,
      "number_in_surah": 5,
      "text_arabic": "فَٱلْمُلْقِيَٰتِ ذِكْرًا",
      "text_translation": "And those [angels] who deliver a message",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5627.mp3"
    },
    {
      "number": 5628,
      "number_in_surah": 6,
      "text_arabic": "عُذْرًا أَوْ نُذْرًا",
      "text_translation": "As justification or warning,",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5628.mp3"
    },
    {
      "number": 5629,
      "number_in_surah": 7,
      "text_arabic": "إِنَّمَا تُوعَدُونَ لَوَٰقِعٌۭ",
      "text_translation": "Indeed, what you are promised is to occur.",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5629.mp3"
    },
    {
      "number": 5630,
      "number_in_surah": 8,
      "text_arabic": "فَإِذَا ٱلنُّجُومُ طُمِسَتْ",
      "text_translation": "So when the stars are obliterated",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5630.mp3"
    },
    {
      "number": 5631,
      "number_in_surah": 9,
      "text_arabic": "وَإِذَا ٱلسَّمَآءُ فُرِجَتْ",
      "text_translation": "And when the heaven is opened",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5631.mp3"
    },
    {
      "number": 5632,
      "number_in_surah": 10,
      "text_arabic": "وَإِذَا ٱلْجِبَالُ نُسِفَتْ",
      "text_translation": "And when the mountains are blown away",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5632.mp3"
    },
    {
      "number": 5633,
      "number_in_surah": 11,
      "text_arabic": "وَإِذَا ٱلرُّسُلُ أُقِّتَتْ",
      "text_translation": "And when the messengers' time has come...",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5633.mp3"
    },
    {
      "number": 5634,
      "number_in_surah": 12,
      "text_arabic": "لِأَىِّ يَوْمٍ أُجِّلَتْ",
      "text_translation": "For what Day was it postponed?",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5634.mp3"
    },
    {
      "number": 5635,
      "number_in_surah": 13,
      "text_arabic": "لِيَوْمِ ٱلْفَصْلِ",
      "text_translation": "For the Day of Judgement.",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5635.mp3"
    },
    {
      "number": 5636,
      "number_in_surah": 14,
      "text_arabic": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ",
      "text_translation": "And what can make you know what is the Day of Judgement?",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5636.mp3"
    },
    {
      "number": 5637,
      "number_in_surah": 15,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5637.mp3"
    },
    {
      "number": 5638,
      "number_in_surah": 16,
      "text_arabic": "أَلَمْ نُهْلِكِ ٱلْأَوَّلِينَ",
      "text_translation": "Did We not destroy the former peoples?",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5638.mp3"
    },
    {
      "number": 5639,
      "number_in_surah": 17,
      "text_arabic": "ثُمَّ نُتْبِعُهُمُ ٱلْءَاخِرِينَ",
      "text_translation": "Then We will follow them with the later ones.",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5639.mp3"
    },
    {
      "number": 5640,
      "number_in_surah": 18,
      "text_arabic": "كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ",
      "text_translation": "Thus do We deal with the criminals.",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5640.mp3"
    },
    {
      "number": 5641,
      "number_in_surah": 19,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 580,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5641.mp3"
    },
    {
      "number": 5642,
      "number_in_surah": 20,
      "text_arabic": "أَلَمْ نَخْلُقكُّم مِّن مَّآءٍۢ مَّهِينٍۢ",
      "text_translation": "Did We not create you from a liquid disdained?",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5642.mp3"
    },
    {
      "number": 5643,
      "number_in_surah": 21,
      "text_arabic": "فَجَعَلْنَٰهُ فِى قَرَارٍۢ مَّكِينٍ",
      "text_translation": "And We placed it in a firm lodging",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5643.mp3"
    },
    {
      "number": 5644,
      "number_in_surah": 22,
      "text_arabic": "إِلَىٰ قَدَرٍۢ مَّعْلُومٍۢ",
      "text_translation": "For a known extent.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5644.mp3"
    },
    {
      "number": 5645,
      "number_in_surah": 23,
      "text_arabic": "فَقَدَرْنَا فَنِعْمَ ٱلْقَٰدِرُونَ",
      "text_translation": "And We determined [it], and excellent [are We] to determine.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5645.mp3"
    },
    {
      "number": 5646,
      "number_in_surah": 24,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5646.mp3"
    },
    {
      "number": 5647,
      "number_in_surah": 25,
      "text_arabic": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ كِفَاتًا",
      "text_translation": "Have We not made the earth a container",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5647.mp3"
    },
    {
      "number": 5648,
      "number_in_surah": 26,
      "text_arabic": "أَحْيَآءًۭ وَأَمْوَٰتًۭا",
      "text_translation": "Of the living and the dead?",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5648.mp3"
    },
    {
      "number": 5649,
      "number_in_surah": 27,
      "text_arabic": "وَجَعَلْنَا فِيهَا رَوَٰسِىَ شَٰمِخَٰتٍۢ وَأَسْقَيْنَٰكُم مَّآءًۭ فُرَاتًۭا",
      "text_translation": "And We placed therein lofty, firmly set mountains and have given you to drink sweet water.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5649.mp3"
    },
    {
      "number": 5650,
      "number_in_surah": 28,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5650.mp3"
    },
    {
      "number": 5651,
      "number_in_surah": 29,
      "text_arabic": "ٱنطَلِقُوٓا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ",
      "text_translation": "[They will be told], \"Proceed to that which you used to deny.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5651.mp3"
    },
    {
      "number": 5652,
      "number_in_surah": 30,
      "text_arabic": "ٱنطَلِقُوٓا۟ إِلَىٰ ظِلٍّۢ ذِى ثَلَٰثِ شُعَبٍۢ",
      "text_translation": "Proceed to a shadow [of smoke] having three columns",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5652.mp3"
    },
    {
      "number": 5653,
      "number_in_surah": 31,
      "text_arabic": "لَّا ظَلِيلٍۢ وَلَا يُغْنِى مِنَ ٱللَّهَبِ",
      "text_translation": "[But having] no cool shade and availing not against the flame.\"",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5653.mp3"
    },
    {
      "number": 5654,
      "number_in_surah": 32,
      "text_arabic": "إِنَّهَا تَرْمِى بِشَرَرٍۢ كَٱلْقَصْرِ",
      "text_translation": "Indeed, it throws sparks [as huge] as a fortress,",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5654.mp3"
    },
    {
      "number": 5655,
      "number_in_surah": 33,
      "text_arabic": "كَأَنَّهُۥ جِمَٰلَتٌۭ صُفْرٌۭ",
      "text_translation": "As if they were yellowish [black] camels.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5655.mp3"
    },
    {
      "number": 5656,
      "number_in_surah": 34,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5656.mp3"
    },
    {
      "number": 5657,
      "number_in_surah": 35,
      "text_arabic": "هَٰذَا يَوْمُ لَا يَنطِقُونَ",
      "text_translation": "This is a Day they will not speak,",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5657.mp3"
    },
    {
      "number": 5658,
      "number_in_surah": 36,
      "text_arabic": "وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ",
      "text_translation": "Nor will it be permitted for them to make an excuse.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5658.mp3"
    },
    {
      "number": 5659,
      "number_in_surah": 37,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5659.mp3"
    },
    {
      "number": 5660,
      "number_in_surah": 38,
      "text_arabic": "هَٰذَا يَوْمُ ٱلْفَصْلِ ۖ جَمَعْنَٰكُمْ وَٱلْأَوَّلِينَ",
      "text_translation": "This is the Day of Judgement; We will have assembled you and the former peoples.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5660.mp3"
    },
    {
      "number": 5661,
      "number_in_surah": 39,
      "text_arabic": "فَإِن كَانَ لَكُمْ كَيْدٌۭ فَكِيدُونِ",
      "text_translation": "So if you have a plan, then plan against Me.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5661.mp3"
    },
    {
      "number": 5662,
      "number_in_surah": 40,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5662.mp3"
    },
    {
      "number": 5663,
      "number_in_surah": 41,
      "text_arabic": "إِنَّ ٱلْمُتَّقِينَ فِى ظِلَٰلٍۢ وَعُيُونٍۢ",
      "text_translation": "Indeed, the righteous will be among shades and springs",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5663.mp3"
    },
    {
      "number": 5664,
      "number_in_surah": 42,
      "text_arabic": "وَفَوَٰكِهَ مِمَّا يَشْتَهُونَ",
      "text_translation": "And fruits from whatever they desire,",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5664.mp3"
    },
    {
      "number": 5665,
      "number_in_surah": 43,
      "text_arabic": "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ",
      "text_translation": "[Being told], \"Eat and drink in satisfaction for what you used to do.\"",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5665.mp3"
    },
    {
      "number": 5666,
      "number_in_surah": 44,
      "text_arabic": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "text_translation": "Indeed, We thus reward the doers of good.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5666.mp3"
    },
    {
      "number": 5667,
      "number_in_surah": 45,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5667.mp3"
    },
    {
      "number": 5668,
      "number_in_surah": 46,
      "text_arabic": "كُلُوا۟ وَتَمَتَّعُوا۟ قَلِيلًا إِنَّكُم مُّجْرِمُونَ",
      "text_translation": "[O disbelievers], eat and enjoy yourselves a little; indeed, you are criminals.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5668.mp3"
    },
    {
      "number": 5669,
      "number_in_surah": 47,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5669.mp3"
    },
    {
      "number": 5670,
      "number_in_surah": 48,
      "text_arabic": "وَإِذَا قِيلَ لَهُمُ ٱرْكَعُوا۟ لَا يَرْكَعُونَ",
      "text_translation": "And when it is said to them, \"Bow [in prayer],\" they do not bow.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5670.mp3"
    },
    {
      "number": 5671,
      "number_in_surah": 49,
      "text_arabic": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "text_translation": "Woe, that Day, to the deniers.",
      "juz": 29,
      "page": 581,
      "audio_url": "https://cdn.islamic.network/quran/audio/128/ar.alafasy/5671.mp3"
    },
    {
      "number": 5672,
